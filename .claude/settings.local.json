{
  "permissions": {
    "allow": [
      "Bash(docker --version)",
      "Bash(docker compose:*)",
      "Bash(docker-compose --version)",
      "Bash(cmd.exe /c \"docker --version\")",
      "Bash(cmd.exe /c \"docker --version && docker compose version\")",
      "Bash(npm --version)",
      "Bash(cmd.exe /c \"node --version && npm --version && psql --version\")",
      "Bash(cmd.exe /c \"where node 2>nul & where npm 2>nul & where psql 2>nul & where docker 2>nul\")",
      "PowerShell(Get-CimInstance Win32_Process -Filter \"Name='node.exe'\")",
      "Bash(node ./node_modules/vite/bin/vite.js)",
      "Bash(curl -s http://localhost:3001/health)",
      "Bash(curl -s http://localhost:3001/posts)",
      "Bash(curl -s -m 2 http://localhost:3001/health)",
      "Bash(curl -s -m 2 http://localhost:3001/posts)",
      "Bash(findstr :3001)",
      "PowerShell(Get-CimInstance Win32_Process -Filter \"ProcessId=25028 OR ProcessId=24772\")",
      "Bash(curl -s -m 3 http://localhost:3001/posts)"
    ]
  }
}
